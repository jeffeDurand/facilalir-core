# Copy to `.env` in the repo root (`.env` is gitignored).
# Only set what you actually use — training/export can run fully offline with local files.

# Hugging Face — needed for some gated/private datasets or higher rate limits.
# Create a token at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxx

# Roboflow — only if you download a dataset via Roboflow API.
# ROBOFLOW_API_KEY=xxxxxxxx

# Weights & Biases — only if you pass `WANDB_API_KEY` to Ultralytics logging.
# WANDB_API_KEY=xxxxxxxx
